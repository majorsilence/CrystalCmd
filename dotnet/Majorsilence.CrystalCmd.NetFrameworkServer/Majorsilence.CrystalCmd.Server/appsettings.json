{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  // Set strong, unique values before use. Left empty so the server ships without working
  // credentials; while empty, Basic auth rejects every request. The server also refuses to
  // start if these are set to the well-known defaults user/password.
  "Credentials": {
    "Username": "",
    "Password": ""
  },
  // JWT is enabled only when Jwt:Key is a real secret of at least 32 bytes. The placeholder
  // below is ignored (JWT stays disabled) so a known key can never be used to forge tokens.
  "Jwt": {
    "Key": "PLACEHOLDER_PLACEHOLDER_PLACEHOLDER_PLACEHOLDER",
    "Issuer": "https://localhost/",
    "Audience": "https://localhost/"
  },
  // Security hardening switches:
  //   "RequireHttps": "true"             -> force TLS (HSTS + redirect) for direct internet exposure
  //   "AllowDefaultCredentials": "true"  -> permit user/password (local testing only)
  //   "PollTokenKey": "<secret>"         -> binds /export/poll handles to the caller (defaults to Jwt:Key)
  "Security": {
    "RequireHttps": "false"
  },
  // "Limits": { "MaxRequestBodyBytes": 104857600 },
  "Server": {
    // to change port numbers use launchSettings.json or set the environment variable "ASPNETCORE_URLS": "http://*:44355;https://*:44356"
    // windows service related settings
    "ServiceName": "CrystalCmdService"
  },
  "ExternalLogs": {
    // LogFile must be set to a path the process access write access, nreco logging
    "LogFile": null,
    // If set, ExternalLogsAssemblyFilePath is used to hook into alternative log backends
    "AssemblyFilePath": "",
    "AssemblyClassName": "",
    "AssemblyFunctionName": ""
  },
  "WorkQueue": {
    "SqlType": "sqlite",
    "SqlConnection": "Data Source=C:\\CrystalCmd\\crystalcmd-workqueue.db;"
    //"SqlType": "psql",
    //"SqlConnection": "Server=localhost;Port=5432;Database=pg_crystalcmd_queue;Userid=postgres;Password=password;Pooling=true;MinPoolSize=2;",
    //"SqlType": "sql",
    //"SqlConnection": "Server=localhost;Database=pg_crystalcmd_queue;User Id=sa;Password=password;"
  }
}